# Copy this file to .env and fill in your key.
#   cp .env.example .env

# --- LLM provider ---
# Supported: groq, openai, anthropic, mock
# Use "mock" to run fully offline with no API key.
# Recommended free option: groq (free tier, Llama 3 models, OpenAI-compatible).
LLM_PROVIDER=groq

# Your API key for the chosen provider.
# Get a free Groq key at https://console.groq.com/keys
GROQ_API_KEY=gsk-your-key-here
# OPENAI_API_KEY=sk-your-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# Model + sampling.
#   groq:   llama-3.3-70b-versatile  (or llama-3.1-8b-instant for speed)
#   openai: gpt-4o-mini
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.1

# --- Agent behaviour ---
# How many reason/act/observe cycles before the agent must answer.
AGENT_MAX_STEPS=5

# --- Tool behaviour ---
# Number of search results to feed back to the agent per query.
SEARCH_MAX_RESULTS=3
# Force the search tool to use bundled fixtures instead of the live web
# (useful for grading without network access).
SEARCH_OFFLINE=false
